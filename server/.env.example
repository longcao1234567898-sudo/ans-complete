# ================= CẤU HÌNH MINI-BACKEND =================
# Sao chép file này thành ".env" rồi điền giá trị

# Cổng chạy server (Render sẽ tự cấp PORT, local dùng 4000)
PORT=4000

# ----- Kết nối MySQL -----
# Local XAMPP: host=localhost, user=root, password để trống
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hop_thu_an_ninh_so

# Khi dùng MySQL cloud (Aiven...) yêu cầu SSL:
#   DB_SSL_CA=/duong/dan/ca.pem   (đường dẫn file CA tải từ Aiven)
# hoặc tạm thời: DB_SSL=true
# DB_SSL_CA=
# DB_SSL=

# ----- AI (key nằm Ở ĐÂY, phía máy chủ — trình duyệt không bao giờ thấy) -----
GEMINI_API_KEY=

# ----- CORS: các địa chỉ frontend được phép gọi API (phân cách bằng dấu phẩy) -----
# localhost:3000/4173/5173 luôn được phép sẵn cho môi trường dev
CORS_ORIGIN=

# Chuỗi bí mật ký JWT (bắt buộc đổi khi production, tạo bằng: openssl rand -hex 32)
JWT_SECRET=
NODE_ENV=development
