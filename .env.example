# ==========================================================
# BACKEND (tuỳ chọn) — địa chỉ mini-backend
# Trống = web chạy chế độ offline (localStorage). Có backend thì điền:
#   Local:      VITE_API_URL=http://localhost:4000
#   Production: VITE_API_URL=https://ten-backend.onrender.com
VITE_API_URL=

# ==========================================================
# TÍCH HỢP AI THẬT CHO TRỢ LÝ HỎI ĐÁP (chọn 1 trong 2)
# ----------------------------------------------------------
# CÁCH DÙNG:
# 1. Sao chép file này thành file tên ".env" (cùng thư mục)
# 2. Điền 1 trong 2 key bên dưới
# 3. Khởi động lại "npm run dev"
#
# Không điền key nào: web vẫn chạy bình thường với câu trả lời mẫu.
# ⚠️ Key đặt ở frontend sẽ lộ khi đưa web lên mạng — chỉ dùng demo/học tập.
# ==========================================================

# LỰA CHỌN 1 — Google Gemini (KHUYÊN DÙNG, CÓ GÓI MIỄN PHÍ)
# Lấy key tại: https://aistudio.google.com/app/apikey
# Đăng nhập Gmail -> bấm "Create API key" -> copy dán vào đây
# Key dạng AIza... (cũ) hoặc AQ.... (chuẩn mới từ 6/2026) đều dùng được
# QUAN TRỌNG: giữ nguyên tên biến VITE_GEMINI_API_KEY, không đổi thành GEMINI_API_KEY
VITE_GEMINI_API_KEY=

# LỰA CHỌN 2 — ChatGPT / OpenAI (cần tài khoản có credit trả phí)
# Lấy key tại: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=
